# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.backup

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dev/test artifacts — not needed for app install
/__tests__/
/tests/
/test-ingestion-doc.md
/vitest.config.ts
/.planning/

# demo/customer-specific content — not needed for app install
/scripts/seed-*.ts
/scripts/reseed-*.ts
/scripts/run-seed.ts
/scripts/create-*-doc.ts
/scripts/migrate-local.ts
/scripts/import-onboarding.ts
/scripts/query-*.ts
/scripts/*.docx
/test-docs/
