# ── Core Configuration ──────────────────────────────────────────────────────
# PostgreSQL database connection string
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/bigpanda_app
# Required extension: pg_trgm (for fuzzy entity matching in Pass 5 change detection)
DATABASE_URL=postgresql://user:password@host:port/database

# Redis connection string for BullMQ job queue and caching
# Format: redis://host:port or rediss://host:port (SSL)
# Example: redis://localhost:6379
REDIS_URL=redis://host:port

# Anthropic Claude API key for AI skills (15 skills total)
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Authentication ──────────────────────────────────────────────────────────
# Full production URL for better-auth callbacks (NO trailing slash)
# Examples: https://bigpanda-app.company.com or http://localhost:3000 (dev only)
BETTER_AUTH_URL=https://your-production-domain.com

# High-entropy secret for better-auth session signing (32+ characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-plus-character-secret-here

# ── Client-Side Configuration ───────────────────────────────────────────────
# Base URL for client-side absolute URL construction (optional)
# Falls back to window.location.origin if not set
# Only needed if SSR contexts require absolute URLs
# NEXT_PUBLIC_BASE_URL=https://your-production-domain.com

# ── SMTP Configuration (for invite emails) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASS=your-app-password-here
SMTP_FROM=your-email@company.com

# ── Runtime ─────────────────────────────────────────────────────────────────
# Set to "production" in deployed environments
NODE_ENV=production
